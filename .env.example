# ── Google Gemini (the brain — only model) ───────────────────
# Get free keys at https://aistudio.google.com/apikey
# JARVIS_GEMINI_KEY is the primary. BACKUP / BACKUP2 / BACKUP3 are tried in
# order, automatically, when the current key hits a rate-limit / quota
# error (HTTP 429 or "RESOURCE_EXHAUSTED"). All are optional — leave blank
# to skip. JARVIS uses ONLY Gemini — no second model pass.
JARVIS_GEMINI_KEY=
JARVIS_GEMINI_KEY_BACKUP=
JARVIS_GEMINI_KEY_BACKUP2=
JARVIS_GEMINI_KEY_BACKUP3=

# Model to use. Free-tier friendly options:
#   gemini-3-flash-preview  (default — Google lists this as free + unlimited
#                            as of 2026; supports tool-calling + vision)
#   gemini-2.0-flash         (fast, supports tool-calling + vision)
#   gemini-2.5-flash         (slightly smarter, same tool support)
#   gemini-2.0-flash-lite    (cheaper, lower rate limits)
#   gemini-flash-latest      (alias for the latest 2.x flash)
JARVIS_MODEL=gemini-3-flash-preview

# ── Personality / behaviour ─────────────────────────────────
JARVIS_NAME=JARVIS
JARVIS_WAKE_WORD=jarvis          # say this to trigger in voice mode (optional)
JARVIS_VOICE=1                   # 1 = speak replies, 0 = text only
JARVIS_STT=1                     # 1 = listen with mic, 0 = type input (CLI only)

JARVIS_PERSONA=jarvis            # jarvis | friday | coach
JARVIS_LANG=en                   # en | hi | te
JARVIS_THEME=stealth             # arc | mark3 | ultron | stealth

# ── Mobile / LAN access ────────────────────────────────────
# Leave blank to keep JARVIS on this PC only (127.0.0.1).
# Set a PIN to allow phones on the same Wi-Fi to connect (they must enter it).
JARVIS_PIN=

# ── Telegram bot (control the laptop from anywhere) ──────────
# 1. In Telegram, message @BotFather, /newbot, copy the token.
# 2. Paste it below and set ENABLED=1.
# 3. Restart the server. DM your bot, send /start, then send JARVIS_PIN.
# 4. ~/.jarvis/telegram_authorized.json will be created with linked chat_ids.
# Delete that file to unlink everyone.
JARVIS_TELEGRAM_ENABLED=0
JARVIS_TELEGRAM_TOKEN=
